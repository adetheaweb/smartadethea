{
  "entities": {
    "Question": {
      "title": "Question",
      "description": "A single question in a quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["multiple_choice", "true_false", "short_answer"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "explanation": { "type": "string" },
        "points": { "type": "number" }
      },
      "required": ["id", "text", "type", "correctAnswer", "points"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "An exam or quiz created by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "teacherId": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "questions": { "type": "array", "items": { "$ref": "#/entities/Question" } },
        "status": { "type": "string", "enum": ["draft", "published", "closed"] },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "teacherId", "durationMinutes", "questions", "status", "createdAt"]
    },
    "QuizAttempt": {
      "title": "QuizAttempt",
      "description": "A student's attempt at a quiz",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "quizId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "answers": { "type": "object", "additionalProperties": { "type": "string" } },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "status": { "type": "string", "enum": ["in_progress", "submitted"] }
      },
      "required": ["id", "quizId", "studentId", "studentName", "answers", "score", "maxScore", "startTime", "status"]
    }
  },
  "firestore": {
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Collection of all quizzes"
    },
    "/attempts/{attemptId}": {
      "schema": "QuizAttempt",
      "description": "Collection of student quiz attempts"
    }
  }
}
